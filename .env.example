# Copy this file to ".env" (same folder) and paste your Anthropic API key to
# enable the optional AI assist (reading messy comments, ranking conflict fixes).
# The app works fully without it; ".env" is gitignored and never committed.
ANTHROPIC_API_KEY=sk-ant-...

# Optional model overrides (defaults shown):
# BA_MODEL_CHEAP=claude-haiku-4-5-20251001
# BA_MODEL_STRONG=claude-opus-4-8
