# --- real / GDPR-sensitive data — NEVER commit -------------------------------
# Input booking data, exports, generated planner data, runtime folders
_info/
output/
export/
data/
import/
templates/

# Real config (course catalog + teacher data + corrections) — ship config.example/ instead
config/teacher_aliases.csv
config/teacher_typos.csv
config/workload_targets.json
config/settings.json
config/course_master.csv
config/course_code_fixes.csv

# Secrets (Anthropic API key etc.)
.env
.env.*
!.env.example
*.key

# --- generated / transient ---------------------------------------------------
__pycache__/
*.pyc
~$*          # Excel lock files
.DS_Store

# PyInstaller build artifacts (the .exe is shipped via Releases, not committed)
build/
dist/
*.exe

# Local machine settings + transient scan artifacts (never publish)
.claude/settings.local.json
.nametokens.json

# Generic, shareable stand-ins live in config.example/ (committed) so the public
# repo / .exe runs with no real or example-specific data.
PROJECT.md
ROADMAP.md

# Generated runtime file (created next to the app)
booking-assistant-rules.md
